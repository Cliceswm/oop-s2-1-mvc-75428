@model IEnumerable<Library.Domain.Book>

@{
    ViewData["Title"] = "Books List";
}

<h1>Books</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Book</a>
</p>

<!-- STEP 8: SIMPLE SEARCH AND FILTER FORM -->
<div class="card mb-4">
    <div class="card-header">
        <h5>Search & Filter Books</h5>
    </div>
    <div class="card-body">
        <form asp-action="Index" method="get">
            <div class="row">
                <!-- Search by Title or Author -->
                <div class="col-md-4">
                    <div class="form-group">
                        <label>Search:</label>
                        <input type="text" name="search" value="@ViewData["CurrentSearch"]" class="form-control" placeholder="Search by title or author..." />
                    </div>
                </div>

                <!-- Filter by Category -->
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Category:</label>
                        <select name="category" class="form-control">
                            <option value="">All Categories</option>
                            @{
                                var categories = ViewData["Categories"] as List<string>;
                                if (categories != null)
                                {
                                    foreach (var cat in categories)
                                    {
                                        if (ViewData["CurrentCategory"]?.ToString() == cat)
                                        {
                                            <option value="@cat" selected>@cat</option>
                                        }
                                        else
                                        {
                                            <option value="@cat">@cat</option>
                                        }
                                    }
                                }
                            }
                        </select>
                    </div>
                </div>

                <!-- Filter by Availability -->
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Availability:</label>
                        <select name="availability" class="form-control">
                            <option value="">All Books</option>
                            
                            @if (ViewData["CurrentAvailability"]?.ToString() == "Available")
                            {
                                <option value="Available" selected>Available Only</option>
                            }
                            else
                            {
                                <option value="Available">Available Only</option>
                            }
                            
                            @if (ViewData["CurrentAvailability"]?.ToString() == "OnLoan")
                            {
                                <option value="OnLoan" selected>On Loan Only</option>
                            }
                            else
                            {
                                <option value="OnLoan">On Loan Only</option>
                            }
                        </select>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">Apply Filters</button>
                        <a asp-action="Index" class="btn btn-secondary">Clear</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Show message if no books found -->
@if (!Model.Any())
{
    <div class="alert alert-info">
        No books found matching your criteria.
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Title)</th>
                <th>@Html.DisplayNameFor(model => model.Author)</th>
                <th>@Html.DisplayNameFor(model => model.Isbn)</th>
                <th>@Html.DisplayNameFor(model => model.Category)</th>
                <th>@Html.DisplayNameFor(model => model.IsAvailable)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Title)</td>
                    <td>@Html.DisplayFor(modelItem => item.Author)</td>
                    <td>@Html.DisplayFor(modelItem => item.Isbn)</td>
                    <td>@Html.DisplayFor(modelItem => item.Category)</td>
                    <td>
                        @if (item.IsAvailable)
                        {
                            <span class="badge bg-success">Available</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">On Loan</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- Simple summary -->
<div class="mt-3">
    <p><strong>Total Books Found:</strong> @Model.Count()</p>
</div>